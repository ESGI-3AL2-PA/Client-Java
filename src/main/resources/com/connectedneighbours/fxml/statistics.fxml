<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.connectedneighbours.controller.StatisticsController"
            styleClass="app-bg">

    <!-- ══════════════ HEADER ══════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

            <Label text="%common.page.statistics" styleClass="header-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="%common.action.close" onAction="#onCloseClick" styleClass="button-ghost"/>
        </HBox>
    </top>

    <!-- ══════════════ CONTENU ══════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-transparent">
            <VBox spacing="20">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <HBox spacing="16">

                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="%common.page.users" styleClass="card-label"/>
                        <Label fx:id="statUsersTotal" text="—" styleClass="card-value"/>
                        <Label fx:id="statUsersTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="%statistics.card.listings" styleClass="card-label"/>
                        <Label fx:id="statListingsTotal" text="—" styleClass="card-value"/>
                        <Label fx:id="statListingsTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="%statistics.card.events" styleClass="card-label"/>
                        <Label fx:id="statEventsTotal" text="—" styleClass="card-value"/>
                        <Label fx:id="statEventsTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="%statistics.card.votes" styleClass="card-label"/>
                        <Label fx:id="statVotesTotal" text="—" styleClass="card-value"/>
                        <Label fx:id="statVotesTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="%common.page.incidents" styleClass="card-label"/>
                        <Label fx:id="statIncidentsTotal" text="—" styleClass="card-value"/>
                        <Label fx:id="statIncidentsTrend" text="" styleClass="card-trend"/>
                    </VBox>

                </HBox>

                <!-- Rangée 2 : les 2 graphiques -->
                <HBox spacing="16">
                    <PieChart fx:id="incidentsByStatusChart" HBox.hgrow="ALWAYS"
                              title="%statistics.chart.byStatus.title" prefHeight="280" legendVisible="true"/>
                    <PieChart fx:id="incidentsByCategoryChart" HBox.hgrow="ALWAYS"
                              title="%statistics.chart.byCategory.title" prefHeight="280" legendVisible="true"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
