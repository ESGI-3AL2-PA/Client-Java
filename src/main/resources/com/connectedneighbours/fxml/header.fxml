<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<HBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.connectedneighbours.controller.HeaderController"
      alignment="CENTER_LEFT" spacing="16"
      styleClass="header">
    <padding>
        <Insets top="14" right="20" bottom="14" left="20"/>
    </padding>

    <Label text="%common.brand.name" styleClass="header-title"/>
    <Label text="%header.badge.admin" styleClass="accent-badge"/>
    <Label fx:id="currentUserLabel" text=""
           style="-fx-font-size: 12px;" styleClass="text-faint"/>

    <!-- Spacer -->
    <Region HBox.hgrow="ALWAYS"/>

    <Button fx:id="btnDashboard" text="%common.page.dashboard"
            onAction="#onDashboardClick" styleClass="nav-button"/>
    <Button fx:id="btnIncidents" text="%common.page.incidents"
            onAction="#onIncidentsClick" styleClass="nav-button"/>
    <Button fx:id="btnUsers" text="%common.page.users"
            onAction="#onUsersClick" styleClass="nav-button"/>
    <Button fx:id="btnStatistics" text="%common.page.statistics"
            onAction="#onStatisticsClick" styleClass="nav-button"/>
    <MenuButton fx:id="btnPlugins" text="%header.nav.plugins" styleClass="nav-button">
        <items>
            <MenuItem text="%header.nav.plugins.social" onAction="#onSocialAnalysisClick"/>
            <MenuItem text="%header.nav.plugins.calendar" onAction="#onLocalCalendarClick"/>
        </items>
    </MenuButton>
    <Button fx:id="btnSettings" text="%common.page.settings"
            onAction="#onSettingsClick" styleClass="nav-button"/>
    <Button fx:id="btnLogout" text="%header.nav.logout"
            onAction="#onLogoutClick" styleClass="nav-button-logout"/>
</HBox>
