<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.connectedneighbours.controller.IncidentController"
            styleClass="app-bg">

    <!-- HEADER -->
    <top>
        <fx:include source="header.fxml" fx:id="header"/>
    </top>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-transparent">
            <VBox spacing="20">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Titre de page -->
                <Label text="Gestion des incidents" styleClass="page-title"/>

                <!-- ── BARRE DE FILTRES + ACTIONS ── -->
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card">
                    <padding>
                        <Insets top="14" right="16" bottom="14" left="16"/>
                    </padding>

                    <Label text="Statut :" styleClass="field-label"/>
                    <ComboBox fx:id="filterStatus" prefWidth="160"
                              promptText="Tous les statuts"/>

                    <Label text="Catégorie :" styleClass="field-label"/>
                    <ComboBox fx:id="filterCategory" prefWidth="180"
                              promptText="Toutes les catégories"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="countLabel" text="— incidents" styleClass="text-faint"/>

                    <Button text="+ Nouvel incident"
                            onAction="#onNewIncidentClick" styleClass="button-primary"/>
                </HBox>

                <!-- ── TABLEAU DES INCIDENTS ── -->
                <VBox spacing="0" styleClass="card">
                    <padding>
                        <Insets top="0" right="0" bottom="0" left="0"/>
                    </padding>

                    <TableView fx:id="incidentsTable"
                               VBox.vgrow="ALWAYS"
                               prefHeight="520" styleClass="table-transparent">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                            <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="130"/>
                            <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                            <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
                            <TableColumn fx:id="colReporter" text="Reporter" prefWidth="140"/>
                            <TableColumn fx:id="colDistrict" text="District" prefWidth="120"/>
                            <TableColumn fx:id="colAssignedTo" text="Assigné à" prefWidth="140"/>
                            <TableColumn fx:id="colCreatedAt" text="Créé le" prefWidth="140"/>
                            <TableColumn fx:id="colUpdatedAt" text="Modifié le" prefWidth="140"/>
                            <TableColumn fx:id="colSynced" text="Sync" prefWidth="50"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun incident trouvé" styleClass="text-faint"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- BARRE DE STATUT -->
    <bottom>
        <HBox spacing="8" alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>
            <Circle fx:id="syncStatusDot" radius="6" fill="GRAY"/>
            <Label fx:id="syncStatusLabel" text="Hors-ligne" styleClass="status-bar-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lastSyncLabel" styleClass="status-bar-secondary"/>
            <Button fx:id="syncNowButton" text="Synchroniser maintenant"
                    onAction="#onSyncNowClick" styleClass="button-ghost"/>
        </HBox>
    </bottom>

</BorderPane>
