<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.connectedneighbours.controller.DashboardController"
            style="-fx-background-color: #f0f2f5;">

    <!-- ══════════════ HEADER ══════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>

            <Label text="Connected Neighbours"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Admin"
                   style="-fx-font-size: 12px; -fx-text-fill: #ffffff;
                          -fx-background-color: #4a6fa5;
                          -fx-background-radius: 4; -fx-padding: 2 8 2 8;"/>
            <Label fx:id="currentUserLabel" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnIncidents" text="Incidents"
                    onAction="#onIncidentsClick"
                    style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
                           -fx-border-radius: 4; -fx-cursor: hand;"/>
            <Button fx:id="btnUsers" text="Utilisateurs"
                    onAction="#onUsersClick"
                    style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
                           -fx-border-radius: 4; -fx-cursor: hand;"/>
            <Button fx:id="btnStatistics" text="Statistiques"
                    onAction="#onStatisticsClick"
                    style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
                           -fx-border-radius: 4; -fx-cursor: hand;"/>
            <Button fx:id="btnSettings" text="Paramètres"
                    onAction="#onSettingsClick"
                    style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
                           -fx-border-radius: 4; -fx-cursor: hand;"/>
            <Button fx:id="btnLogout" text="Déconnexion"
                    onAction="#onLogoutClick"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ══════════════ CONTENU PRINCIPAL ══════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Titre de page -->
                <Label text="Tableau de bord"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <!-- ── CARTES DE STATISTIQUES ── -->
                <HBox spacing="16">
                    <!-- Incidents ouverts -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Incidents ouverts"
                               style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
                        <Label fx:id="statOpenIncidents" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                        <Label fx:id="statOpenTrend" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>

                    <!-- En cours -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="En cours"
                               style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
                        <Label fx:id="statInProgress" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                        <Label fx:id="statInProgressTrend" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>

                    <!-- Résolus -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Résolus (30j)"
                               style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
                        <Label fx:id="statResolved" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        <Label fx:id="statResolvedTrend" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>

                    <!-- Non synchronisés -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Non synchronisés"
                               style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
                        <Label fx:id="statUnsynced" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                        <Label text="En attente de sync"
                               style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>

                <!-- ── TABLEAU INCIDENTS RÉCENTS + ALERTES ── -->
                <HBox spacing="16">

                    <!-- Incidents récents -->
                    <VBox HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Incidents récents"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Voir tout" onAction="#onIncidentsClick"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #4a6fa5; -fx-cursor: hand;
                                           -fx-font-size: 12px;"/>
                        </HBox>

                        <TableView fx:id="incidentsTable"
                                   prefHeight="280"
                                   style="-fx-background-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="220"/>
                                <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="140"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucun incident" style="-fx-text-fill: #aaaaaa;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- Alertes récentes -->
                    <VBox prefWidth="280" spacing="10"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                                 -fx-border-color: #e8e8e8; -fx-border-radius: 8;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label text="Alertes"
                               style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <VBox fx:id="alertsContainer" spacing="8">
                            <Label text="Chargement..."
                                   style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ── BOUTONS D'ACTIONS RAPIDES ── -->
                <VBox spacing="10"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 8;
                             -fx-border-color: #e8e8e8; -fx-border-radius: 8;">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Actions rapides"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <Button text="+ Nouvel incident"
                                onAction="#onNewIncidentClick"
                                style="-fx-background-color: #4a6fa5; -fx-text-fill: white;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
                        <Button text="↗ Exporter stats"
                                onAction="#onExportClick"
                                style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Barre de statut -->
    <bottom>
        <HBox spacing="8" alignment="CENTER_LEFT"
              style="-fx-background-color: #f5f5f5;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>
            <Circle fx:id="syncStatusDot" radius="6" fill="GRAY"/>
            <Label fx:id="syncStatusLabel" text="Hors-ligne"
                   style="-fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lastSyncLabel"
                   style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
            <Button fx:id="syncNowButton" text="Synchroniser maintenant"
                    onAction="#onSyncNowClick"
                    style="-fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>