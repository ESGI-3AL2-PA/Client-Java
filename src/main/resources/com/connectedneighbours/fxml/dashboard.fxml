<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.connectedneighbours.controller.DashboardController"
            styleClass="app-bg">

    <!-- HEADER  -->
    <top>
        <fx:include source="header.fxml" fx:id="header"/>
    </top>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-transparent">
            <VBox spacing="20">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Titre de page -->
                <Label text="Tableau de bord" styleClass="page-title"/>

                <!-- ── CARTES DE STATISTIQUES ── -->
                <HBox spacing="16">
                    <!-- Incidents ouverts -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Incidents ouverts" styleClass="card-label"/>
                        <Label fx:id="statOpenIncidents" text="—"
                               styleClass="card-value,card-value-open"/>
                        <Label fx:id="statOpenTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <!-- En cours -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="En cours" styleClass="card-label"/>
                        <Label fx:id="statInProgress" text="—"
                               styleClass="card-value,card-value-progress"/>
                        <Label fx:id="statInProgressTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <!-- Résolus -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Résolus (30j)" styleClass="card-label"/>
                        <Label fx:id="statResolved" text="—"
                               styleClass="card-value,card-value-resolved"/>
                        <Label fx:id="statResolvedTrend" text="" styleClass="card-trend"/>
                    </VBox>

                    <!-- Non synchronisés -->
                    <VBox HBox.hgrow="ALWAYS" spacing="6" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Non synchronisés" styleClass="card-label"/>
                        <Label fx:id="statUnsynced" text="—"
                               styleClass="card-value,card-value-unsynced"/>
                        <Label text="En attente de sync" styleClass="card-trend"/>
                    </VBox>
                </HBox>

                <!-- ── TABLEAU INCIDENTS RÉCENTS + ALERTES ── -->
                <HBox spacing="16">

                    <!-- Incidents récents -->
                    <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Incidents récents" styleClass="card-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Voir tout" onAction="#onIncidentsClick"
                                    styleClass="link-button"/>
                        </HBox>

                        <TableView fx:id="incidentsTable"
                                   prefHeight="280" styleClass="table-transparent">
                            <columns>
                                <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="220"/>
                                <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="140"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucun incident" styleClass="text-faint"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- Alertes récentes -->
                    <VBox prefWidth="280" spacing="10" styleClass="card">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label text="Alertes" styleClass="card-title"/>

                        <VBox fx:id="alertsContainer" spacing="8">
                            <Label text="Chargement..." styleClass="text-faint"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ── BOUTONS D'ACTIONS RAPIDES ── -->
                <VBox spacing="10" styleClass="card">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Actions rapides" styleClass="card-title"/>
                    <HBox spacing="10">
                        <Button text="+ Nouvel incident"
                                onAction="#onNewIncidentClick" styleClass="button-primary"/>
                        <Button text="↗ Exporter stats"
                                onAction="#onExportClick" styleClass="button-accent"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Barre de statut -->
    <bottom>
        <HBox spacing="8" alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>
            <Circle fx:id="syncStatusDot" radius="6" fill="GRAY"/>
            <Label fx:id="syncStatusLabel" text="Hors-ligne" styleClass="status-bar-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lastSyncLabel" styleClass="status-bar-secondary"/>
            <Button fx:id="conflictsButton" text="Conflits" visible="false" managed="false"
                    onAction="#onConflictsClick" styleClass="button-ghost"/>
            <Button fx:id="syncNowButton" text="Synchroniser maintenant"
                    onAction="#onSyncNowClick" styleClass="button-ghost"/>
        </HBox>
    </bottom>

</BorderPane>