<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
			xmlns="http://javafx.com/javafx/21"
			fx:controller="com.connectedneighbours.controller.SettingsController"
			style="-fx-background-color: #f0f2f5;">

	<!-- ══════════════ HEADER ══════════════ -->
	<top>
		<HBox alignment="CENTER_LEFT" spacing="12"
			  style="-fx-background-color: #ffffff;
					 -fx-border-color: #e0e0e0;
					 -fx-border-width: 0 0 1 0;">
			<padding>
				<Insets top="14" right="20" bottom="14" left="20"/>
			</padding>

			<Label text="Paramètres"
				   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
			<Region HBox.hgrow="ALWAYS"/>
			<Button text="Fermer" onAction="#onCloseClick"
					style="-fx-background-color: transparent;
						   -fx-border-color: #e0e0e0;
						   -fx-border-radius: 4;
						   -fx-cursor: hand;"/>
		</HBox>
	</top>

	<!-- ══════════════ CONTENU ══════════════ -->
	<center>
		<VBox spacing="16">
			<padding>
				<Insets top="24" right="24" bottom="24" left="24"/>
			</padding>

			<VBox spacing="14"
				  style="-fx-background-color: #ffffff; -fx-background-radius: 8;
						 -fx-border-color: #e8e8e8; -fx-border-radius: 8;
						 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
				<padding>
					<Insets top="16" right="16" bottom="16" left="16"/>
				</padding>

				<Label text="Configuration de l’API"
					   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

				<GridPane hgap="12" vgap="10">
					<columnConstraints>
						<ColumnConstraints minWidth="140"/>
						<ColumnConstraints hgrow="ALWAYS"/>
					</columnConstraints>

					<Label text="Schéma" GridPane.rowIndex="0" GridPane.columnIndex="0"
						   style="-fx-text-fill: #444444;"/>
					<ChoiceBox fx:id="schemeChoice" prefWidth="200"
							   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

					<Label text="Hôte" GridPane.rowIndex="1" GridPane.columnIndex="0"
						   style="-fx-text-fill: #444444;"/>
					<TextField fx:id="hostField" promptText="ex: api.exemple.com ou https://api.exemple.com"
							   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

					<Label text="Port (optionnel)" GridPane.rowIndex="2" GridPane.columnIndex="0"
						   style="-fx-text-fill: #444444;"/>
					<TextField fx:id="portField" promptText="ex: 3000 (laisser vide pour 80/443)"
							   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
				</GridPane>

				<Separator/>

				<HBox spacing="8" alignment="CENTER_LEFT">
					<Label text="URL de base :" style="-fx-text-fill: #444444;"/>
					<Label fx:id="baseUrlLabel" text="—"
						   style="-fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
				</HBox>

				<HBox spacing="10" alignment="CENTER_LEFT">
					<Button text="Tester la connexion" onAction="#onTestConnectionClick"
							style="-fx-background-color: #4a6fa5; -fx-text-fill: white;
								   -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
					<Label fx:id="testResultLabel" text=""
						   style="-fx-font-size: 12px;"/>
				</HBox>
			</VBox>

			<Region VBox.vgrow="ALWAYS"/>
		</VBox>
	</center>

	<!-- ══════════════ ACTIONS ══════════════ -->
	<bottom>
		<HBox spacing="10" alignment="CENTER_RIGHT"
			  style="-fx-background-color: #f5f5f5;
					 -fx-border-color: #e0e0e0;
					 -fx-border-width: 1 0 0 0;">
			<padding>
				<Insets top="12" right="16" bottom="12" left="16"/>
			</padding>

			<Button text="Réinitialiser" onAction="#onResetClick"
					style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
						   -fx-border-radius: 4; -fx-cursor: hand;"/>
			<Region HBox.hgrow="ALWAYS"/>
			<Button text="Annuler" onAction="#onCancelClick"
					style="-fx-background-color: transparent; -fx-border-color: #e0e0e0;
						   -fx-border-radius: 4; -fx-cursor: hand;"/>
			<Button text="Enregistrer" onAction="#onSaveClick"
					style="-fx-background-color: #27ae60; -fx-text-fill: white;
						   -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
		</HBox>
	</bottom>

</BorderPane>
