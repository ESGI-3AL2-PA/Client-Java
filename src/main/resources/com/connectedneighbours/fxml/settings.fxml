<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
			xmlns="http://javafx.com/javafx/21"
			fx:controller="com.connectedneighbours.controller.SettingsController"
			styleClass="app-bg">

	<!-- ══════════════ HEADER ══════════════ -->
	<top>
		<HBox alignment="CENTER_LEFT" spacing="12" styleClass="header">
			<padding>
				<Insets top="14" right="20" bottom="14" left="20"/>
			</padding>

			<Label text="%common.page.settings" styleClass="header-title"/>
			<Region HBox.hgrow="ALWAYS"/>
			<Button text="%common.action.close" onAction="#onCloseClick" styleClass="button-ghost"/>
		</HBox>
	</top>

	<!-- ══════════════ CONTENU ══════════════ -->
	<center>
		<ScrollPane fitToWidth="true" styleClass="scroll-transparent">
		<VBox spacing="16">
			<padding>
				<Insets top="24" right="24" bottom="24" left="24"/>
			</padding>

			<!-- ─── Configuration de l'API ─── -->
			<VBox spacing="14" styleClass="card">
				<padding>
					<Insets top="16" right="16" bottom="16" left="16"/>
				</padding>

				<Label text="%settings.api.card.title" styleClass="card-title"/>

				<GridPane hgap="12" vgap="10">
					<columnConstraints>
						<ColumnConstraints minWidth="140"/>
						<ColumnConstraints hgrow="ALWAYS"/>
					</columnConstraints>

					<Label text="%settings.api.scheme.label" GridPane.rowIndex="0" GridPane.columnIndex="0"
						   styleClass="field-label"/>
					<ChoiceBox fx:id="schemeChoice" prefWidth="200"
							   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

					<Label text="%settings.api.host.label" GridPane.rowIndex="1" GridPane.columnIndex="0"
						   styleClass="field-label"/>
					<TextField fx:id="hostField" promptText="%settings.api.host.prompt"
							   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

					<Label text="%settings.api.port.label" GridPane.rowIndex="2" GridPane.columnIndex="0"
						   styleClass="field-label"/>
					<TextField fx:id="portField" promptText="%settings.api.port.prompt"
							   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
				</GridPane>

				<Separator/>

				<HBox spacing="8" alignment="CENTER_LEFT">
					<Label text="%settings.api.baseUrl.label" styleClass="field-label"/>
					<Label fx:id="baseUrlLabel" text="—"
						   style="-fx-font-weight: bold;" styleClass="header-title"/>
				</HBox>

				<HBox spacing="10" alignment="CENTER_LEFT">
					<Button text="%settings.api.testConnection.button" onAction="#onTestConnectionClick"
							styleClass="button-primary"/>
					<Label fx:id="testResultLabel" text=""
						   style="-fx-font-size: 12px;"/>
				</HBox>
			</VBox>

			<!-- ─── Apparence (thèmes) ─── -->
			<VBox spacing="14" styleClass="card">
				<padding>
					<Insets top="16" right="16" bottom="16" left="16"/>
				</padding>

				<Label text="%settings.appearance.card.title" styleClass="card-title"/>

				<GridPane hgap="12" vgap="10">
					<columnConstraints>
						<ColumnConstraints minWidth="140"/>
						<ColumnConstraints hgrow="ALWAYS"/>
					</columnConstraints>

					<Label text="%settings.appearance.theme.label" GridPane.rowIndex="0" GridPane.columnIndex="0"
						   styleClass="field-label"/>
					<HBox spacing="8" alignment="CENTER_LEFT"
						  GridPane.rowIndex="0" GridPane.columnIndex="1">
						<ComboBox fx:id="themeCombo" prefWidth="240"/>
						<Button text="%common.action.reload" onAction="#onReloadThemesClick"
								styleClass="button-ghost"/>
					</HBox>
				</GridPane>

				<Label fx:id="themeHintLabel" styleClass="text-faint" maxWidth="620"
					   text="%settings.appearance.hint"
					   wrapText="true"/>
			</VBox>

			<!-- ─── Langue ─── -->
			<VBox spacing="14" styleClass="card">
				<padding>
					<Insets top="16" right="16" bottom="16" left="16"/>
				</padding>

				<Label text="%settings.language.card.title" styleClass="card-title"/>

				<GridPane hgap="12" vgap="10">
					<columnConstraints>
						<ColumnConstraints minWidth="140"/>
						<ColumnConstraints hgrow="ALWAYS"/>
					</columnConstraints>

					<Label text="%settings.language.label" GridPane.rowIndex="0" GridPane.columnIndex="0"
						   styleClass="field-label"/>
					<HBox spacing="8" alignment="CENTER_LEFT"
						  GridPane.rowIndex="0" GridPane.columnIndex="1">
						<ComboBox fx:id="languageCombo" prefWidth="240"/>
						<Button text="%common.action.apply" onAction="#onApplyLanguageClick"
								styleClass="button-ghost"/>
					</HBox>
				</GridPane>

				<Label fx:id="languageHintLabel" styleClass="text-faint"
					   text="%settings.language.hint"
					   wrapText="true"/>
			</VBox>

			<Region VBox.vgrow="ALWAYS"/>
		</VBox>
		</ScrollPane>
	</center>

	<!-- ══════════════ ACTIONS ══════════════ -->
	<bottom>
		<HBox spacing="10" alignment="CENTER_RIGHT" styleClass="action-bar">
			<padding>
				<Insets top="12" right="16" bottom="12" left="16"/>
			</padding>

			<Button text="%common.action.reset" onAction="#onResetClick" styleClass="button-ghost"/>
			<Region HBox.hgrow="ALWAYS"/>
			<Button text="%common.action.cancel" onAction="#onCancelClick" styleClass="button-ghost"/>
			<Button text="%common.action.save" onAction="#onSaveClick" styleClass="button-success"/>
		</HBox>
	</bottom>

</BorderPane>
